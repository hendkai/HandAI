{
  "$comment": "Copy to ~/.config/handai/handai.json and edit. Adding a provider or a remote box is a pure config edit — no code changes. ${VARS} are expanded from the environment.",

  "skills": {
    "$comment": "The one shared skills place. Every provider with a skills_dir is symlinked here, so a skill installed once shows up in all tools.",
    "dir": "${HANDAI_STATE}/skills"
  },

  "providers": [
    {
      "id": "claude",
      "label": "Claude Code",
      "command": ["claude"],
      "auth": "oauth-device",
      "auth_methods": ["oauth-device", "token-env"],
      "token_env": "ANTHROPIC_API_KEY",
      "login_command": ["claude", "login"],
      "allowed_modes": ["local", "devbox", "cloud"],
      "skills_dir": "~/.claude/skills"
    },
    {
      "id": "codex",
      "label": "Codex CLI",
      "command": ["codex"],
      "auth": "oauth-device",
      "auth_methods": ["oauth-device", "token-env"],
      "token_env": "OPENAI_API_KEY",
      "login_command": ["codex", "login", "--device-auth"],
      "allowed_modes": ["local", "devbox"],
      "skills_dir": "~/.codex/skills"
    },
    {
      "id": "codex-remote",
      "label": "Codex (remote/cloud)",
      "command": ["codex", "--cloud"],
      "auth": "oauth-device",
      "auth_methods": ["oauth-device", "token-env"],
      "token_env": "OPENAI_API_KEY",
      "login_command": ["codex", "login", "--device-auth"],
      "allowed_modes": ["devbox", "cloud"]
    },
    {
      "id": "hermes",
      "label": "Hermes Agent",
      "command": ["hermes"],
      "auth": "oauth-device",
      "auth_methods": ["oauth-device", "token-env"],
      "token_env": "OPENROUTER_API_KEY",
      "login_command": ["hermes", "setup", "--portal"],
      "allowed_modes": ["local", "devbox", "cloud"],
      "skills_dir": "~/.hermes/skills"
    },
    {
      "id": "opencode",
      "label": "opencode",
      "command": ["opencode"],
      "auth": "oauth-device",
      "auth_methods": ["oauth-device", "token-env"],
      "token_env": "OPENCODE_API_KEY",
      "login_command": ["opencode", "auth", "login"],
      "allowed_modes": ["local", "devbox"],
      "skills_dir": "~/.config/opencode/skills"
    },
    {
      "id": "openclaw",
      "label": "OpenClaw",
      "command": ["openclaw", "tui"],
      "auth": "oauth-device",
      "auth_methods": ["oauth-device", "token-env"],
      "token_env": "OPENAI_API_KEY",
      "login_command": ["openclaw", "models", "auth", "login"],
      "allowed_modes": ["local", "devbox", "cloud"],
      "skills_dir": "~/.openclaw/skills"
    }
  ],

  "modes": [
    {
      "id": "local",
      "label": "Local (on-device)",
      "transport": "local",
      "default_workdir": "~/work"
    },
    {
      "id": "devbox",
      "label": "Devbox (SSH)",
      "transport": "ssh",
      "host": "dev@devbox.local",
      "default_workdir": "~/projects"
    },
    {
      "id": "cloud",
      "label": "Cloud sandbox (SSH)",
      "transport": "ssh",
      "host": "${HANDAI_CLOUD_HOST}",
      "default_workdir": "/workspace"
    }
  ],

  "recent_workdirs": [
    "~/work",
    "~/projects/handai"
  ]
}
