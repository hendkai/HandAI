{
  "$comment": "Offline dev config: providers point at the fake agent stub (auth none), local mode only. Run with:  HANDAI_DEV=$PWD/dev HANDAI_CONFIG=dev/handai.dev.json python -m handai   (see `make demo`). No accounts, no network needed.",

  "providers": [
    { "id": "fake-claude", "label": "Fake Claude",
      "command": ["sh", "${HANDAI_DEV}/fake/agent.sh", "claude"],
      "auth": "none", "allowed_modes": ["local"] },

    { "id": "fake-codex", "label": "Fake Codex",
      "command": ["sh", "${HANDAI_DEV}/fake/agent.sh", "codex"],
      "auth": "none", "allowed_modes": ["local"] },

    { "id": "fake-remote", "label": "Fake Remote (ssh localhost)",
      "command": ["sh", "${HANDAI_DEV}/fake/agent.sh", "remote"],
      "auth": "none", "allowed_modes": ["localhost"] }
  ],

  "modes": [
    { "id": "local", "label": "Local (on-device)", "transport": "local",
      "default_workdir": "." },
    { "id": "localhost", "label": "Loopback SSH (needs sshd)", "transport": "ssh",
      "host": "localhost", "default_workdir": "." }
  ],

  "recent_workdirs": ["."]
}
