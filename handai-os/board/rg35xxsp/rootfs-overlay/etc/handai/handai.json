{
  "$comment": "On-device defaults. Add real computers and gateways in Settings > Remote Devices; they persist under /data. Provider OAuth credentials and preferences also live under /data.",

  "providers": [
    { "id": "claude", "label": "Claude Code", "command": ["claude"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["claude", "auth", "login"],
      "oauth_profiles": [
        {"label": "CLAUDE SUBSCRIPTION", "command": ["claude", "auth", "login"]}
      ],
      "allowed_modes": ["local", "devbox", "cloud"],
      "skills_dir": "~/.claude/skills" },

    { "id": "codex", "label": "Codex CLI", "command": ["codex"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["codex", "login", "--device-auth"],
      "oauth_profiles": [
        {"label": "CHATGPT / CODEX SUBSCRIPTION", "command": ["codex", "login", "--device-auth"]}
      ],
      "allowed_modes": ["local", "devbox"],
      "skills_dir": "~/.codex/skills" },

    { "id": "codex-remote", "label": "Codex Cloud", "command": ["codex", "cloud"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["codex", "login", "--device-auth"],
      "oauth_profiles": [
        {"label": "CHATGPT / CODEX SUBSCRIPTION", "command": ["codex", "login", "--device-auth"]}
      ],
      "allowed_modes": ["devbox", "cloud"] },

    { "id": "hermes", "label": "Hermes Agent", "command": ["hermes"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["hermes", "auth", "add", "nous", "--type", "oauth", "--no-browser"],
      "oauth_profiles": [
        {"label": "NOUS PORTAL", "command": ["hermes", "auth", "add", "nous", "--type", "oauth", "--no-browser"]},
        {"label": "OPENAI CODEX", "command": ["hermes", "auth", "add", "openai-codex", "--type", "oauth", "--no-browser"]},
        {"label": "XAI / GROK", "command": ["hermes", "auth", "add", "xai-oauth", "--type", "oauth", "--no-browser", "--manual-paste"]}
      ],
      "allowed_modes": ["local", "devbox", "cloud"], "skills_dir": "~/.hermes/skills" },

    { "id": "opencode", "label": "opencode", "command": ["opencode"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["opencode", "auth", "login", "-p", "openai", "-m", "ChatGPT Pro/Plus (headless)"],
      "oauth_profiles": [
        {"label": "OPENAI CHATGPT PRO/PLUS", "command": ["opencode", "auth", "login", "-p", "openai", "-m", "ChatGPT Pro/Plus (headless)"], "requires_tty": true},
        {"label": "XAI SUPERGROK", "command": ["opencode", "auth", "login", "-p", "xai", "-m", "xAI Grok OAuth (Headless / Remote / VPS)"], "requires_tty": true},
        {"label": "GITHUB.COM COPILOT", "command": ["opencode", "auth", "login", "-p", "github-copilot", "-m", "Login with GitHub Copilot"], "initial_input": "\r", "requires_tty": true}
      ],
      "allowed_modes": ["local", "devbox"],
      "skills_dir": "~/.config/opencode/skills" },

    { "id": "openclaw", "label": "OpenClaw", "command": ["openclaw", "tui"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["openclaw", "models", "auth", "login", "--provider", "openai", "--device-code"],
      "oauth_profiles": [
        {"label": "OPENAI CHATGPT / CODEX", "command": ["openclaw", "models", "auth", "login", "--provider", "openai", "--device-code"], "requires_tty": true}
      ],
      "allowed_modes": ["local", "devbox", "cloud"], "skills_dir": "~/.openclaw/skills" }
  ],

  "modes": [
    { "id": "local",  "label": "Local (on-device)", "transport": "local",
      "default_workdir": "~/work" }
  ],

  "recent_workdirs": ["~/work"]
}
