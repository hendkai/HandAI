{
  "$comment": "On-device default config. Edit remote hosts (devbox/cloud) to your boxes. Lives on the read-only rootfs; user tokens + recent live under /data (HANDAI_STATE).",

  "providers": [
    { "id": "claude", "label": "Claude Code", "command": ["claude"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["claude", "auth", "login"],
      "oauth_profiles": [
        {"label": "CLAUDE SUBSCRIPTION", "command": ["claude", "auth", "login"]}
      ],
      "allowed_modes": ["local", "devbox", "cloud"] },

    { "id": "codex", "label": "Codex CLI", "command": ["codex"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["codex", "login", "--device-auth"],
      "oauth_profiles": [
        {"label": "CHATGPT / CODEX SUBSCRIPTION", "command": ["codex", "login", "--device-auth"]}
      ],
      "allowed_modes": ["local", "devbox"] },

    { "id": "codex-remote", "label": "Codex (remote/cloud)", "command": ["codex", "--cloud"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["codex", "login", "--device-auth"],
      "oauth_profiles": [
        {"label": "CHATGPT / CODEX SUBSCRIPTION", "command": ["codex", "login", "--device-auth"]}
      ],
      "allowed_modes": ["devbox", "cloud"] },

    { "id": "hermes", "label": "Hermes Agent", "command": ["hermes"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["hermes", "auth", "add", "nous", "--type", "oauth"],
      "oauth_profiles": [
        {"label": "NOUS PORTAL", "command": ["hermes", "auth", "add", "nous", "--type", "oauth"]},
        {"label": "OPENAI CODEX", "command": ["hermes", "auth", "add", "openai-codex", "--type", "oauth"]},
        {"label": "XAI / GROK", "command": ["hermes", "auth", "add", "xai-oauth"], "requires_tty": true}
      ],
      "allowed_modes": ["local", "devbox", "cloud"], "skills_dir": "~/.hermes/skills" },

    { "id": "opencode", "label": "opencode", "command": ["opencode"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["opencode", "auth", "login", "-p", "openai", "-m", "ChatGPT Pro/Plus (headless)"],
      "oauth_profiles": [
        {"label": "OPENAI CHATGPT PRO/PLUS", "command": ["opencode", "auth", "login", "-p", "openai", "-m", "ChatGPT Pro/Plus (headless)"]},
        {"label": "XAI SUPERGROK", "command": ["opencode", "auth", "login", "-p", "xai", "-m", "xAI Grok OAuth (Headless / Remote / VPS)"]},
        {"label": "GITHUB COPILOT", "command": ["opencode", "auth", "login", "-p", "github-copilot", "-m", "Login with GitHub Copilot"], "initial_input": "\r"}
      ],
      "allowed_modes": ["local", "devbox"] },

    { "id": "openclaw", "label": "OpenClaw", "command": ["openclaw", "tui"],
      "auth": "oauth-device", "auth_methods": ["oauth-device"],
      "login_command": ["openclaw", "models", "auth", "login", "--provider", "openai", "--device-code"],
      "oauth_profiles": [
        {"label": "OPENAI CHATGPT / CODEX", "command": ["openclaw", "models", "auth", "login", "--provider", "openai", "--device-code"], "requires_tty": true}
      ],
      "allowed_modes": ["local", "devbox", "cloud"], "skills_dir": "~/.openclaw/skills" }
  ],

  "modes": [
    { "id": "local",  "label": "Local (on-device)", "transport": "local",
      "default_workdir": "~/work" },
    { "id": "devbox", "label": "Devbox (SSH)", "transport": "ssh",
      "host": "dev@devbox.local", "default_workdir": "~/projects" },
    { "id": "cloud",  "label": "Cloud sandbox (SSH)", "transport": "ssh",
      "host": "${HANDAI_CLOUD_HOST}", "default_workdir": "/workspace" }
  ],

  "recent_workdirs": ["~/work"]
}
