#!/bin/sh
# System-wide PipeWire/WirePlumber instance for ALSA and Bluetooth HFP capture.

RUNTIME=/run/handai-audio
LOG=/data/handai/audio.log

route_h700_codec() {
	# Match the proven KNULLI H700 codec route. PipeWire controls stream volume,
	# while these ALSA switches connect the internal DAC to the speaker output.
	command -v amixer >/dev/null 2>&1 || return 0
	amixer -c 0 -q sset "OutputL Mixer DACL" on >>"$LOG" 2>&1 || true
	amixer -c 0 -q sset "OutputL Mixer DACR" off >>"$LOG" 2>&1 || true
	amixer -c 0 -q sset "OutputR Mixer DACL" off >>"$LOG" 2>&1 || true
	amixer -c 0 -q sset "OutputR Mixer DACR" on >>"$LOG" 2>&1 || true
	amixer -c 0 -q sset LINEOUT on >>"$LOG" 2>&1 || true
}

start() {
	/usr/sbin/handai-boot-log DRIVERS "loading Mali and audio drivers"
	PYTHONPATH=/opt/handai /usr/bin/python3 -m handai.bootdiag \
		--progress 62 "LOADING DRIVERS" >/dev/null 2>&1 || true
	mkdir -p "$RUNTIME" /data/handai
	chmod 0700 "$RUNTIME"
	route_h700_codec
	if [ -f /lib/modules/mali_kbase.ko ] && [ ! -e /dev/mali0 ]; then
		insmod /lib/modules/mali_kbase.ko >>"$LOG" 2>&1 || true
	fi
	if command -v pipewire >/dev/null 2>&1 && ! pidof pipewire >/dev/null 2>&1; then
		XDG_RUNTIME_DIR="$RUNTIME" PIPEWIRE_RUNTIME_DIR="$RUNTIME" \
			pipewire >>"$LOG" 2>&1 &
	fi
	sleep 1
	if command -v wireplumber >/dev/null 2>&1 && ! pidof wireplumber >/dev/null 2>&1; then
		XDG_RUNTIME_DIR="$RUNTIME" PIPEWIRE_RUNTIME_DIR="$RUNTIME" \
			wireplumber >>"$LOG" 2>&1 &
	fi
	(
		sleep 2
		XDG_RUNTIME_DIR="$RUNTIME" PIPEWIRE_RUNTIME_DIR="$RUNTIME" \
			wpctl status >>"$LOG" 2>&1 || true
	) &
	PYTHONPATH=/opt/handai /usr/bin/python3 -m handai.bootdiag \
		--progress 72 "DRIVERS READY" >/dev/null 2>&1 || true
	/usr/sbin/handai-boot-log DRIVERS \
		"ready; mali0=$([ -e /dev/mali0 ] && echo yes || echo no)"
}

stop() {
	killall wireplumber pipewire 2>/dev/null || true
}

case "$1" in
	start) start ;;
	stop) stop ;;
	restart) stop; start ;;
	*) echo "usage: $0 {start|stop|restart}"; exit 1 ;;
esac
