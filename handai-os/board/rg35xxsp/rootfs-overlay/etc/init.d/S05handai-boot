#!/bin/sh
# The existence of this userspace script proves that the kernel and HandAI
# SquashFS have mounted successfully. Show both verified milestones early.

progress() {
	PYTHONPATH=/opt/handai /usr/bin/python3 -m handai.bootdiag \
		--progress "$1" "$2" >/dev/null 2>&1 || true
}

case "$1" in
	start)
		/usr/sbin/handai-boot-log KERNEL "HandAI userspace reached"
		progress 28 "KERNEL READY"
		/usr/sbin/handai-boot-log FILESYSTEM "HandAI SquashFS mounted"
		progress 44 "FILESYSTEM READY"
		;;
esac
