#!/bin/sh
# HandAI: the cockpit IS the session. No login getty — boot straight in and
# respawn on exit so "Quit" just returns to a fresh cockpit.

# Board-specific overrides (tty, wifi iface) live here; QEMU sets HANDAI_TTY=ttyAMA0.
[ -f /etc/default/handai ] && . /etc/default/handai
HANDAI_TTY="${HANDAI_TTY:-/dev/tty1}"
HANDAI_UI="${HANDAI_UI:-pixel}"
HANDAI_FULLSCREEN="${HANDAI_FULLSCREEN:-1}"

DAEMON_ENV="HOME=/data/handai/home HERMES_HOME=/data/handai/home/.hermes XDG_CONFIG_HOME=/data/handai/home/.config XDG_RUNTIME_DIR=/run/handai-audio PIPEWIRE_RUNTIME_DIR=/run/handai-audio HANDAI_CONFIG=/etc/handai/handai.json HANDAI_STATE=/data/handai PYTHONPATH=/opt/handai HANDAI_TMUX_CONF=/etc/handai/tmux.conf HANDAI_UI=$HANDAI_UI HANDAI_FULLSCREEN=$HANDAI_FULLSCREEN npm_config_prefix=/data/handai/npm npm_config_cache=/data/handai/npm-cache PATH=/data/handai/npm/bin:/data/handai/home/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin SDL_VIDEODRIVER=mali TERM=linux"

start() {
	# mount the persistent /data partition if one exists (device only). Node name
	# is board-specific, so try label first, then common mmc nodes. On QEMU none
	# of these exist and /data is just a directory on the rootfs — that's fine.
	mkdir -p /data
	if ! mountpoint -q /data 2>/dev/null; then
		for dev in /dev/disk/by-label/handai-data /dev/mmcblk0p4 /dev/mmcblk1p4; do
			if [ -e "$dev" ]; then
				[ "$(blkid -s LABEL -o value "$dev" 2>/dev/null)" = "handai-data" ] ||
					continue
				mount "$dev" /data 2>/dev/null && break
			fi
		done
	fi
	mkdir -p /data/handai /data/handai/home/.config
	/usr/sbin/handai-boot-log STORAGE \
		"data-mounted=$(mountpoint -q /data && echo yes || echo no)"
	/usr/sbin/handai-boot-log NETWORK "starting network services"
	env $DAEMON_ENV /usr/bin/python3 -m handai.bootdiag \
		--progress 82 "STARTING NETWORK" >>/data/handai/cockpit.log 2>&1 || true
	# Tailscale keeps node identity on the persistent data partition. Buildroot's
	# package has no BusyBox/SysV service, so start the daemon here after /data is
	# mounted. Login itself is initiated from the cockpit and completed by phone.
	if command -v tailscaled >/dev/null 2>&1 && ! pidof tailscaled >/dev/null 2>&1; then
		mkdir -p /data/tailscale /var/run/tailscale
		tailscaled --state=/data/tailscale/tailscaled.state \
			--socket=/var/run/tailscale/tailscaled.sock \
			>/data/handai/tailscaled.log 2>&1 &
	fi
	# boot marker on the console (init stdout) — CI/QEMU smoke test greps this
	echo "[handai] boot ok — starting cockpit on $HANDAI_TTY"
	# bring up WiFi in the background (non-fatal if no adapter yet)
	/opt/handai/net/up.sh >/data/handai/net.log 2>&1 &
	/usr/sbin/handai-boot-log GUI "starting SDL cockpit"
	env $DAEMON_ENV /usr/bin/python3 -m handai.bootdiag \
		--progress 96 "STARTING GUI" >>/data/handai/cockpit.log 2>&1 || true

	# run the cockpit on tty1, respawn forever
	rm -f /run/handai-gui-ready
	(
		while true; do
			if [ "$HANDAI_UI" = "text" ]; then
				# curses needs a real output tty. Keep stderr in the diagnostic
				# log while rendering the QEMU/recovery UI on the console.
				env $DAEMON_ENV \
					/usr/bin/python3 -m handai <"$HANDAI_TTY" \
					>"$HANDAI_TTY" 2>>/data/handai/cockpit.log
			else
				env $DAEMON_ENV \
					/usr/bin/python3 -m handai <"$HANDAI_TTY" \
					>>/data/handai/cockpit.log 2>&1
			fi
			status=$?
			/usr/sbin/handai-boot-log GUI_ERROR "cockpit exited with code $status"
			env $DAEMON_ENV /usr/bin/python3 -m handai.bootdiag \
				--progress 96 --error "GUI FAILED - CODE $status" \
				>>/data/handai/cockpit.log 2>&1 || true
			sleep 1
		done
	) &
	echo $! > /var/run/handai.pid
	attempt=0
	while [ "$attempt" -lt 40 ] && [ ! -e /run/handai-gui-ready ]; do
		attempt=$((attempt + 1))
		sleep 0.25
	done
	if [ -e /run/handai-gui-ready ]; then
		echo "[handai] gui ready OK"
		/usr/sbin/handai-boot-log GUI_READY "cockpit frontend initialized"
	else
		echo "[handai] gui ready timeout"
		tail -n 40 /data/handai/cockpit.log 2>/dev/null || true
		/usr/sbin/handai-boot-log GUI_ERROR \
			"cockpit did not publish ready marker within 10 seconds"
	fi

	# Publish one delayed, read-only hardware acceptance report into the FAT
	# boot log. The user can insert the SD card into Windows and send us this
	# file even when networking or the GUI is broken.
	(
		sleep 15
		env $DAEMON_ENV /usr/bin/handai-hardware-report \
			--output /data/handai/hardware-report-latest.json \
			>/data/handai/hardware-report-latest.txt 2>&1
		status=$?
		/usr/sbin/handai-boot-log SELF_TEST \
			"hardware acceptance exit code $status"
	) &
}

stop() {
	[ -f /var/run/handai.pid ] && kill "$(cat /var/run/handai.pid)" 2>/dev/null
}

case "$1" in
	start) start ;;
	stop)  stop ;;
	restart) stop; start ;;
	*) echo "usage: $0 {start|stop|restart}"; exit 1 ;;
esac
